def cmd_list(args):
    """List available sessions."""
    users_to_check = []
    if args.all_users:
        for d in Path("/home").iterdir():
            if d.is_dir() and (d / ".claude" / "projects").exists():
                users_to_check.append(d.name)
        if (Path.home() / ".claude" / "projects").exists():
            users_to_check.append(os.getenv("USER", "root"))
    else:
        users_to_check.append(args.user or os.getenv("USER", "root"))

    active_pids = get_active_pids()
    all_sessions = []

    for user in users_to_check:
        projects = get_projects_dir(user)
        if projects is None or not projects.exists():
            continue
        for proj_dir in sorted(projects.iterdir()):
            if not proj_dir.is_dir():
                continue
            jsonl_files = sorted(proj_dir.glob("*.jsonl"))
            if not jsonl_files:
                continue
            project_cwd = read_first_cwd_cached(jsonl_files[0])
            if not project_cwd:
                project_cwd = f"(dir: {proj_dir.name})"
            if args.project and project_cwd != args.project:
                continue
            for jsonl in jsonl_files:
                stat = jsonl.stat()
                sid = jsonl.stem
                pids = active_pids.get(sid, [])
                compacted = is_compacted(jsonl) if stat.st_size < 50_000_000 else None
                if pids:
                    status = "active"
                elif compacted:
                    status = "compacted"
                else:
                    status = "idle"

                companion_dir = jsonl.parent / sid
                companion_count = (
                    sum(1 for _ in companion_dir.rglob("*") if _.is_file()) if companion_dir.is_dir() else 0
                )

                age_seconds = (
                    datetime.now(timezone.utc) - datetime.fromtimestamp(stat.st_mtime, tz=timezone.utc)
                ).total_seconds()
                if age_seconds < 3600:
                    age = f"{int(age_seconds // 60)}m"
                elif age_seconds < 86400:
                    age = f"{int(age_seconds // 3600)}h"
                else:
                    age = f"{int(age_seconds // 86400)}d"

                session = {
                    "sessionId": sid,
                    "user": user,
                    "project": project_cwd,
                    "encodedCwd": proj_dir.name,
                    "jsonlPath": str(jsonl),
                    "sizeBytes": stat.st_size,
                    "sizeHuman": f"{stat.st_size / 1048576:.1f}MB"
                    if stat.st_size > 1048576
                    else f"{stat.st_size // 1024}KB",
                    "records": count_records(jsonl) if stat.st_size < 50_000_000 else -1,
                    "status": status,
                    "pid": pids[0] if pids else None,
                    "compacted": compacted if compacted is not None else False,
                    "hasCompanion": companion_dir.is_dir(),
                    "companionFiles": companion_count,
                    "lastModified": datetime.fromtimestamp(stat.st_mtime, tz=timezone.utc).isoformat(),
                    "createdAt": datetime.fromtimestamp(stat.st_ctime, tz=timezone.utc).isoformat(),
                    "age": age,
                }
                all_sessions.append(session)

    all_sessions.sort(key=lambda s: s["lastModified"], reverse=True)

    list_user = None if args.all_users else (args.user or os.getenv("USER", "root"))

    if args.json:
        print(
            json.dumps(
                {
                    "command": "list",
                    "user": list_user,
                    "sessions": all_sessions,
                    "warnings": [],
                },
                indent=2,
            )
        )
    else:
        if not all_sessions:
            print("No sessions found.")
            return
        print(f"{'SESSION ID':<40} {'PROJECT':<25} {'SIZE':>7} {'RECORDS':>8} {'STATUS':>10} {'AGE':>5}")
        print("-" * 100)
        for s in all_sessions:
            records = str(s["records"]) if s["records"] >= 0 else "?"
            print(
                f"{s['sessionId'][:36]:<40} {s['project'][:24]:<25} {s['sizeHuman']:>7} {records:>8} {s['status']:>10} {s['age']:>5}"
            )
        print(f"\n{len(all_sessions)} sessions found")


def cmd_fork(args):
    """Fork a session to a target directory."""
    jsonl_path, source_cwds, suggestions = find_session(args.session_id)

    if jsonl_path is None:
        if args.json:
            if suggestions and any(isinstance(s, tuple) for s in suggestions):
                print(
                    json.dumps(
                        {
                            "command": "fork",
                            "status": "error",
                            "exitCode": 1,
                            "error": "Ambiguous session ID",
                            "detail": f"Multiple sessions match prefix '{args.session_id}'",
                            "suggestions": [f"{s[2]} ({s[1]})" for s in suggestions],
                        },
                        indent=2,
                    )
                )
            else:
                print(
                    json.dumps(
                        {
                            "command": "fork",
                            "status": "error",
                            "exitCode": 1,
                            "error": "Source session not found",
                            "detail": f"No JSONL matching '{args.session_id}'",
                            "suggestions": suggestions if suggestions else [],
                        },
                        indent=2,
                    )
                )
        else:
            if suggestions and any(isinstance(s, tuple) for s in suggestions):
                print(f"Ambiguous session ID '{args.session_id}'. Did you mean:")
                for s in suggestions:
                    print(f"  {s[2]} ({s[1]})")
            else:
                print(f"Session not found: {args.session_id}")
                if suggestions:
                    print("Available sessions:")
                    for s in suggestions[:5]:
                        print(f"  {s}")
        sys.exit(1)

    source_cwd = max(source_cwds, key=source_cwds.get) if source_cwds else ""
    source_id = jsonl_path.stem
    source_size = jsonl_path.stat().st_size
    warnings = []

    if len(source_cwds) > 1:
        cwd_list = ", ".join(f"{c} ({n})" for c, n in sorted(source_cwds.items(), key=lambda x: -x[1]))
        warnings.append(f"Source has multiple CWDs (prior forks?): {cwd_list} — ALL will be rewritten to target")

    active_pids = get_active_pids()
    pids = active_pids.get(source_id, [])
    if pids:
        warnings.append(f"Source session is ACTIVE (PID {pids[0]})")

    compacted = is_compacted(jsonl_path) if source_size < 50_000_000 else False
    if compacted:
        warnings.append("Source session has been COMPACTED — fork gets summary context only")

    if source_size > 10_000_000:
        warnings.append(f"Large session ({source_size // 1048576}MB) — fork may take a moment")

    source_records = count_records(jsonl_path) if source_size < 50_000_000 else -1
    source_chain_n, source_non_chain_n = count_chain_kinds(jsonl_path)

    target_cwd = os.path.abspath(args.target)
    target_user = args.user or os.getenv("USER", "root")
    target_home = get_home(target_user)

    if target_home is None:
        msg = f"User '{target_user}' not found"
        if args.json:
            print(
                json.dumps(
                    {"command": "fork", "status": "error", "exitCode": 2, "error": msg, "detail": "", "suggestions": []},
                    indent=2,
                )
            )
        else:
            print(msg)
        sys.exit(2)

    projects_base = get_projects_dir(target_user)
    encoding_method = "new-directory"
    target_projects_dir: Optional[Path] = None
    try:
        found_dir = find_project_dir(target_cwd, target_user)
    except ValueError as e:
        if args.json:
            print(
                json.dumps(
                    {
                        "command": "fork",
                        "status": "error",
                        "exitCode": 3,
                        "error": "Ambiguous project directory",
                        "detail": str(e),
                        "suggestions": [],
                    },
                    indent=2,
                )
            )
        else:
            print(f"Error: {e}")
        sys.exit(3)

    if found_dir is not None:
        target_projects_dir = found_dir
        encoding_method = infer_encoding_method(target_cwd, found_dir)
    else:
        target_projects_dir = projects_base / encode_cwd(target_cwd)
        encoding_method = "new-directory"

    target_dir_exists = os.path.isdir(target_cwd)

    if not target_dir_exists and args.no_create:
        msg = f"Target directory does not exist: {target_cwd}. Run without --no-create to auto-create."
        if args.json:
            print(
                json.dumps(
                    {"command": "fork", "status": "error", "exitCode": 3, "error": msg, "detail": "", "suggestions": []},
                    indent=2,
                )
            )
        else:
            print(msg)
        sys.exit(3)

    target_claude_dir = target_home / ".claude"
    target_has_claude = (target_home / ".local" / "bin" / "claude").exists() or shutil.which("claude") is not None
    if not target_has_claude:
        warnings.append(f"Claude Code not found for user {target_user}")

    cleanup_protected = False
    target_settings = target_claude_dir / "settings.json"
    if target_settings.exists():
        try:
            settings = json.loads(target_settings.read_text())
            if settings.get("cleanupPeriodDays", 30) > 365:
                cleanup_protected = True
        except (json.JSONDecodeError, OSError):
            pass
    if not cleanup_protected:
        warnings.append(f"Target user {target_user} sessions may auto-delete after 30 days")

    target_has_claude_md = os.path.isfile(os.path.join(target_cwd, "CLAUDE.md"))
    if not target_has_claude_md and target_dir_exists:
        warnings.append("No CLAUDE.md at target")

    source_companion = jsonl_path.parent / source_id
    companion_count = (
        sum(1 for _ in source_companion.rglob("*") if _.is_file()) if source_companion.is_dir() else 0
    )

    fork_id = str(uuid.uuid4())
    while (target_projects_dir / f"{fork_id}.jsonl").exists():
        fork_id = str(uuid.uuid4())

    cwds_to_rewrite = {c: n for c, n in source_cwds.items() if c != target_cwd}
    needs_cwd_rewrite = bool(cwds_to_rewrite)
    user_change = target_user if target_user != os.getenv("USER", "root") else None

    if args.dry_run:
        result = {
            "command": "fork",
            "status": "dry-run",
            "wouldDo": {
                "source": str(jsonl_path),
                "target": str(target_projects_dir / f"{fork_id}.jsonl"),
                "cwdRewrite": {
                    "from": list(cwds_to_rewrite.keys()),
                    "to": target_cwd,
                    "recordsAffected": sum(cwds_to_rewrite.values()),
                }
                if needs_cwd_rewrite
                else None,
                "userChange": user_change,
                "createDir": not target_dir_exists,
                "companionFiles": companion_count,
            },
            "checks": {
                "sourceExists": True,
                "sourceActive": bool(pids),
                "sourceActivePid": pids[0] if pids else None,
                "sourceCompacted": compacted,
                "sourceRecords": source_records,
                "sourceChainRecords": source_chain_n,
                "sourceNonChainRecords": source_non_chain_n,
                "sourceSizeHuman": f"{source_size // 1048576}MB" if source_size > 1048576 else f"{source_size // 1024}KB",
                "targetDirExists": target_dir_exists,
                "targetHasClaudeMd": target_has_claude_md,
                "targetUserHasClaude": target_has_claude,
                "targetCleanupProtected": cleanup_protected,
                "encodingMethod": encoding_method,
            },
            "warnings": warnings,
        }
        if args.json:
            print(json.dumps(result, indent=2))
        else:
            print("DRY RUN — no changes made\n")
            print(f"Source:  {jsonl_path}")
            print(f"         {source_cwd}, {source_size // 1024}KB, {source_records} records")
            if compacted:
                print("         ⚠ COMPACTED")
            if pids:
                print(f"         ⚠ ACTIVE (PID {pids[0]})")
            print(f"\nTarget:  {target_projects_dir / f'{fork_id}.jsonl'}")
            print(f"         {target_cwd} (as {target_user})")
            if needs_cwd_rewrite:
                print(f"         CWD rewrite: {source_cwd} → {target_cwd}")
            if not target_dir_exists:
                print(f"         Would create: {target_cwd}")
            if companion_count:
                print(f"         {companion_count} companion files")
            if warnings:
                print("\nWarnings:")
                for w in warnings:
                    print(f"  ⚠ {w}")
            print(f"\nResume: cd {target_cwd} && claude --resume {fork_id}")
        return

    if not args.json:
        print(f"Source:  {source_id[:12]}... ({source_cwd}, {source_size // 1024}KB)")
        print(f"Target:  {target_cwd} (as {target_user})")
        for w in warnings:
            print(f"  ⚠ {w}")
        response = input("\nProceed? [y/n] ")
        if response.lower() != "y":
            print("Aborted.")
            return

    if not target_dir_exists:
        os.makedirs(target_cwd, exist_ok=True)
    os.makedirs(target_projects_dir, exist_ok=True)
    os.makedirs(target_claude_dir / "projects", exist_ok=True)

    target_jsonl = target_projects_dir / f"{fork_id}.jsonl"
    cwd_rewritten = 0
    session_id_rewritten = 0
    records_written = 0
    chain_records = 0
    non_chain_records = 0
    pre_copy_size = jsonl_path.stat().st_size

    with open(jsonl_path) as src, open(target_jsonl, "w") as dst:
        for line in src:
            try:
                obj = json.loads(line)
                original_cwd = obj.get("cwd")
                original_sid = obj.get("sessionId")
                result = fork_record(obj, target_cwd, fork_id)
                if is_chain_participant(obj):
                    chain_records += 1
                else:
                    non_chain_records += 1
                if result.get("cwd") != original_cwd:
                    cwd_rewritten += 1
                if result.get("sessionId") != original_sid:
                    session_id_rewritten += 1
                dst.write(json.dumps(result) + "\n")
                records_written += 1
            except json.JSONDecodeError:
                dst.write(line)
                records_written += 1

    post_copy_size = jsonl_path.stat().st_size
    if post_copy_size != pre_copy_size:
        warnings.append(f"Source grew by {post_copy_size - pre_copy_size} bytes during copy")

    last_cleaned = False
    if not args.no_session_cleanup:
        if not validate_last_record(target_jsonl):
            clean_last_record(target_jsonl)
            last_cleaned = True

    companion_copied = 0
    if not args.no_companion and source_companion.is_dir():
        target_companion = target_projects_dir / fork_id
        shutil.copytree(source_companion, target_companion)
        companion_copied = sum(1 for _ in target_companion.rglob("*") if _.is_file())

    if user_change:
        import pwd

        try:
            pw = pwd.getpwnam(target_user)
            os.chown(target_jsonl, pw.pw_uid, pw.pw_gid)
            if (target_projects_dir / fork_id).is_dir():
                for root, dirs, files in os.walk(target_projects_dir / fork_id):
                    for d in dirs:
                        os.chown(os.path.join(root, d), pw.pw_uid, pw.pw_gid)
                    for f in files:
                        os.chown(os.path.join(root, f), pw.pw_uid, pw.pw_gid)
        except (KeyError, PermissionError) as e:
            warnings.append(f"Failed to chown: {e}")

    chain = verify_chain(target_jsonl)
    if chain["broken"] > 0:
        if args.json:
            print(
                json.dumps(
                    {
                        "command": "fork",
                        "status": "error",
                        "exitCode": 5,
                        "error": "Chain integrity failed",
                        "detail": f"{chain['broken']} broken links",
                        "suggestions": [],
                    },
                    indent=2,
                )
            )
        else:
            print(f"ERROR: Chain integrity failed — {chain['broken']} broken links")
        sys.exit(5)

    target_size = target_jsonl.stat().st_size
    resume_cmd = f"cd {target_cwd} && claude --resume {fork_id}"
    if user_change:
        resume_cmd = f"su - {target_user} -c '{resume_cmd}'"

    if args.json:
        print(
            json.dumps(
                {
                    "command": "fork",
                    "status": "success",
                    "source": {
                        "sessionId": source_id,
                        "project": source_cwd,
                        "sizeBytes": source_size,
                        "records": source_records,
                        "compacted": compacted,
                    },
                    "fork": {
                        "sessionId": fork_id,
                        "project": target_cwd,
                        "user": target_user,
                        "jsonlPath": str(target_jsonl),
                        "sizeBytes": target_size,
                        "recordsWritten": records_written,
                        "chainRecords": chain_records,
                        "nonChainRecords": non_chain_records,
                        "cwdFieldsRewritten": cwd_rewritten,
                        "sessionIdFieldsRewritten": session_id_rewritten,
                        "companionFilesCopied": companion_copied,
                        "lastRecordCleaned": last_cleaned,
                    },
                    "chain": {
                        "entries": chain["entries"],
                        "nonChainEntries": chain["nonChainEntries"],
                        "roots": chain["roots"],
                        "leaves": chain["leaves"],
                        "branches": chain["branches"],
                        "broken": chain["broken"],
                        "warnings": chain["warnings"],
                        "badLines": chain["badLines"],
                    },
                    "resume": resume_cmd,
                    "warnings": warnings,
                },
                indent=2,
            )
        )
    else:
        print("\nFork complete.")
        print(f"  Source:     {source_id[:12]}... ({source_cwd})")
        print(f"  Fork:       {fork_id}")
        print(f"  Written:    {records_written} records ({chain_records} chain + {non_chain_records} metadata) ({target_size // 1024}KB)")
        print(f"  Re-stamped: {session_id_rewritten} sessionId, {cwd_rewritten} cwd")
        if companion_copied:
            print(f"  Companion:  {companion_copied} files")
        if last_cleaned:
            print("  Cleanup:    corrupted last record removed")
        print(
            f"  Chain:      {chain['entries']} entries, {chain['roots']} roots, {chain['leaves']} leaves, {chain['broken']} broken"
        )
        if warnings:
            print("\nWarnings:")
            for w in warnings:
                print(f"  ⚠ {w}")
        print(f"\nTo resume:\n  {resume_cmd}")


