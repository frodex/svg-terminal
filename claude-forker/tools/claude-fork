def main():
    parser = argparse.ArgumentParser(prog="claude-fork", add_help=False)
    parser.add_argument("--json", action="store_true")
    subparsers = parser.add_subparsers(dest="command")

    help_p = subparsers.add_parser("help", add_help=False)
    help_p.add_argument("command_name", nargs="?", default=None)

    schema_p = subparsers.add_parser("schema", add_help=False)
    schema_p.add_argument("command_name", nargs="?", default=None)

    list_p = subparsers.add_parser("list", add_help=False)
    list_p.add_argument("--user", default=None)
    list_p.add_argument("--all-users", action="store_true")
    list_p.add_argument("--project", default=None)
    list_p.add_argument("--json", action="store_true", dest="json_flag")

    fork_p = subparsers.add_parser("fork", add_help=False)
    fork_p.add_argument("session_id")
    fork_p.add_argument("target")
    fork_p.add_argument("--user", default=None)
    fork_p.add_argument("--dry-run", action="store_true")
    fork_p.add_argument("--no-companion", action="store_true")
    fork_p.add_argument("--no-create", action="store_true")
    fork_p.add_argument("--no-session-cleanup", action="store_true")
    fork_p.add_argument("--json", action="store_true", dest="json_flag")

    args = parser.parse_args()
    if hasattr(args, "json_flag") and args.json_flag:
        args.json = True

    if args.command is None or args.command == "help":
        if not hasattr(args, "command_name"):
            args.command_name = None
        cmd_help(args)
    elif args.command == "list":
        cmd_list(args)
    elif args.command == "fork":
        cmd_fork(args)
    elif args.command == "schema":
        cmd_schema(args)
    else:
        cmd_help(args)


if __name__ == "__main__":
    main()
