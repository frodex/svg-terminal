#!/usr/bin/env python3
"""claude-fork — Fork Claude Code sessions across projects and users.

See SPEC.md for full documentation.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

VERSION = "0.2.0"

MAX_SANITIZED_LENGTH = 200

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def encode_cwd(path: str) -> str:
    """Encode a directory path the way Claude Code does (sanitizePath).

    Every non-alphanumeric character becomes '-' (per-character, no run
    collapsing). Paths > 200 chars are truncated + djb2 hash suffix.
    """
    sanitized = re.sub(r"[^a-zA-Z0-9]", "-", path)
    if len(sanitized) <= MAX_SANITIZED_LENGTH:
        return sanitized
    hash_val = _djb2_hash(path)
    return f"{sanitized[:MAX_SANITIZED_LENGTH]}-{hash_val}"


def _int_to_base36(n: int) -> str:
    """Non-negative integer to base-36 (matching JS Number.toString(36))."""
    if n == 0:
        return "0"
    digits = "0123456789abcdefghijklmnopqrstuvwxyz"
    result = []
    while n > 0:
        result.append(digits[n % 36])
        n //= 36
    return "".join(reversed(result))


def _djb2_hash(s: str) -> str:
    """djb2 hash matching Claude Code simpleHash() fallback (signed 32-bit)."""
    h = 0
    for c in s:
        h = (h << 5) - h + ord(c)
        h = h & 0xFFFFFFFF
        if h >= 0x80000000:
            h -= 0x100000000
    return _int_to_base36(abs(h))


def get_home(user: str = None) -> Optional[Path]:
    """Get a user's home directory."""
    if user is None or user == os.getenv("USER", "root"):
        return Path.home()
    import pwd

    try:
        return Path(pwd.getpwnam(user).pw_dir)
    except KeyError:
        return None


def get_projects_dir(user: str = None) -> Optional[Path]:
    """Get the .claude/projects directory for a user."""
    home = get_home(user)
    if home is None:
        return None
    return home / ".claude" / "projects"


def get_sessions_dir() -> Path:
    """Get the session index directory."""
    return Path.home() / ".claude" / "sessions"


def get_active_pids() -> dict:
    """Read session index, return {sessionId: [pids]} for live processes."""
    sessions_dir = get_sessions_dir()
    active = {}
    if not sessions_dir.exists():
        return active
    for f in sessions_dir.glob("*.json"):
        try:
            data = json.loads(f.read_text())
            sid = data.get("sessionId", "")
            pid = int(f.stem)
            try:
                os.kill(pid, 0)
                active.setdefault(sid, []).append(pid)
            except OSError:
                pass
        except (json.JSONDecodeError, ValueError):
            pass
    return active


def count_records(jsonl_path: Path) -> int:
    """Count lines in a JSONL file."""
    count = 0
    with open(jsonl_path) as f:
        for _ in f:
            count += 1
    return count


def is_compacted(jsonl_path: Path) -> bool:
    """Check if a session has been compacted."""
    with open(jsonl_path) as f:
        for line in f:
            try:
                obj = json.loads(line)
                if obj.get("subtype") == "compact_boundary":
                    return True
            except json.JSONDecodeError:
                pass
    return False


def read_first_cwd_from_jsonl(jsonl_path: Path, max_lines: int = 50) -> str:
    """First cwd from the first JSONL record that has cwd set (up to max_lines)."""
    with open(jsonl_path) as f:
        for i, line in enumerate(f):
            if i >= max_lines:
                break
            try:
                obj = json.loads(line)
                cwd = obj.get("cwd")
                if cwd:
                    return cwd
            except json.JSONDecodeError:
                continue
    return ""


_read_first_cwd_cache: dict[str, str] = {}


def read_first_cwd_cached(jsonl_path: Path) -> str:
    """Process-lifetime cache over read_first_cwd_from_jsonl."""
    key = str(jsonl_path.resolve())
    if key not in _read_first_cwd_cache:
        _read_first_cwd_cache[key] = read_first_cwd_from_jsonl(jsonl_path)
    return _read_first_cwd_cache[key]


def read_cwds_from_jsonl(jsonl_path: Path) -> dict:
    """Read all unique CWD values from a JSONL and their counts."""
    cwds = {}
    with open(jsonl_path) as f:
        for line in f:
            try:
                obj = json.loads(line)
                c = obj.get("cwd", "")
                if c:
                    cwds[c] = cwds.get(c, 0) + 1
            except json.JSONDecodeError:
                pass
    return cwds


def find_project_dir(project_path: str, user: str = None) -> Optional[Path]:
    """Resolve existing ~/.claude/projects/<encoded-cwd> directory if present."""
    projects = get_projects_dir(user)
    if projects is None or not projects.exists():
        return None

    exact = projects / encode_cwd(project_path)
    if exact.is_dir():
        return exact

    legacy = projects / project_path.replace("/", "-")
    if legacy.is_dir():
        return legacy

    sanitized = re.sub(r"[^a-zA-Z0-9]", "-", project_path)
    if len(sanitized) <= MAX_SANITIZED_LENGTH:
        return None

    prefix = sanitized[:MAX_SANITIZED_LENGTH] + "-"
    matches = [d for d in projects.iterdir() if d.is_dir() and d.name.startswith(prefix)]

    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        raise ValueError(f"Ambiguous prefix match for '{project_path}': {[m.name for m in matches]}")
    return None


def infer_encoding_method(project_path: str, resolved: Path) -> str:
    """How find_project_dir matched (for dry-run / checks)."""
    if resolved.name == encode_cwd(project_path):
        return "current"
    if resolved.name == project_path.replace("/", "-"):
        return "legacy-compat"
    return "prefix-fallback"


CHAIN_PARTICIPANT_TYPES = frozenset({"user", "assistant", "system", "attachment"})


def is_chain_participant(obj: dict) -> bool:
    """Transcript messages that participate in the parentUuid chain."""
    if obj.get("type") in CHAIN_PARTICIPANT_TYPES:
        return True
    if obj.get("uuid") is not None and "parentUuid" in obj:
        return True
    return False


def fork_record(obj: dict, target_cwd: str, fork_id: str) -> dict:
    """Process one JSONL record during fork. Returns a new dict."""
    result = {**obj}
    if "sessionId" not in result:
        return result
    result["sessionId"] = fork_id
    if is_chain_participant(result):
        if result.get("cwd") and result["cwd"] != target_cwd:
            result["cwd"] = target_cwd
    return result


def count_chain_kinds(jsonl_path: Path) -> tuple[int, int]:
    """Count chain vs non-chain JSONL records (parseable lines only)."""
    chain = non_chain = 0
    with open(jsonl_path) as f:
        for line in f:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if is_chain_participant(obj):
                chain += 1
            else:
                non_chain += 1
    return chain, non_chain


def list_git_worktree_paths(repo_cwd: str) -> list[str]:
    """Absolute paths of all git worktrees (including main checkout)."""
    try:
        result = subprocess.run(
            ["git", "worktree", "list", "--porcelain"],
            cwd=repo_cwd,
            capture_output=True,
            text=True,
            timeout=5,
        )
        if result.returncode != 0:
            return []
        return [
            line[len("worktree ") :]
            for line in result.stdout.split("\n")
            if line.startswith("worktree ")
        ]
    except (subprocess.SubprocessError, FileNotFoundError, OSError):
        return []


def find_session(session_id: str, user: str = None) -> tuple:
    """Find a session JSONL by full or partial ID."""
    projects = get_projects_dir(user)
    if projects is None or not projects.exists():
        return None, None, []

    matches = []
    scanned_dirs: set[str] = set()
    for proj_dir in sorted(projects.iterdir()):
        if not proj_dir.is_dir():
            continue
        scanned_dirs.add(proj_dir.name)
        for jsonl in proj_dir.glob("*.jsonl"):
            stem = jsonl.stem
            if stem == session_id:
                cwds = read_cwds_from_jsonl(jsonl)
                return jsonl, cwds, []
            if stem.startswith(session_id):
                matches.append((jsonl, proj_dir, stem))

    if len(matches) == 1:
        cwds = read_cwds_from_jsonl(matches[0][0])
        return matches[0][0], cwds, []
    if len(matches) > 1:
        return None, None, matches

    cwd = os.getcwd()
    for wt_path in list_git_worktree_paths(cwd):
        encoded = encode_cwd(wt_path)
        if encoded in scanned_dirs:
            continue
        wt_proj_dir = projects / encoded
        if not wt_proj_dir.is_dir():
            legacy = wt_path.replace("/", "-")
            if legacy in scanned_dirs:
                continue
            wt_proj_dir = projects / legacy
            if not wt_proj_dir.is_dir():
                continue
        for jsonl in wt_proj_dir.glob("*.jsonl"):
            stem = jsonl.stem
            if stem == session_id or stem.startswith(session_id):
                matches.append((jsonl, wt_proj_dir, stem))

    if len(matches) == 1:
        cwds = read_cwds_from_jsonl(matches[0][0])
        return matches[0][0], cwds, []
    if len(matches) > 1:
        return None, None, matches

    suggestions = []
    for proj_dir in sorted(projects.iterdir()):
        if not proj_dir.is_dir():
            continue
        for jsonl in proj_dir.glob("*.jsonl"):
            cwd_val = read_first_cwd_from_jsonl(jsonl)
            display = cwd_val if cwd_val else f"(dir: {proj_dir.name})"
            size = jsonl.stat().st_size
            mtime = datetime.fromtimestamp(jsonl.stat().st_mtime).strftime("%b %d")
            suggestions.append(f"{jsonl.stem} ({display}, {size // 1024}KB, {mtime})")
    return None, None, suggestions[:10]


def validate_last_record(jsonl_path: Path) -> bool:
    """Check if the last line is valid JSON. Returns True if clean."""
    with open(jsonl_path, "rb") as f:
        f.seek(0, 2)
        size = f.tell()
        if size == 0:
            return True
        read_size = min(size, 65536)
        f.seek(size - read_size)
        chunk = f.read()
        lines = chunk.split(b"\n")
        last = b""
        for line in reversed(lines):
            if line.strip():
                last = line
                break
        if not last:
            return True
        try:
            json.loads(last)
            return True
        except json.JSONDecodeError:
            return False


def clean_last_record(jsonl_path: Path):
    """Remove the last line if it's invalid JSON."""
    with open(jsonl_path, "rb") as f:
        content = f.read()
    lines = content.split(b"\n")
    while lines and not lines[-1].strip():
        lines.pop()
    if not lines:
        return
    try:
        json.loads(lines[-1])
    except json.JSONDecodeError:
        lines.pop()
        with open(jsonl_path, "wb") as f:
            f.write(b"\n".join(lines) + b"\n")


def verify_chain(jsonl_path: Path) -> dict:
    """Verify parentUuid chain integrity (single pass over chain participants)."""
    entries: set = set()
    parent_refs = {}
    children = {}
    roots = 0
    non_chain = 0
    warnings = []
    bad_lines = 0

    with open(jsonl_path) as f:
        for line_num, line in enumerate(f, 1):
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                bad_lines += 1
                continue

            if not is_chain_participant(obj):
                non_chain += 1
                continue

            uid = obj.get("uuid")
            if not uid:
                warnings.append(f"Line {line_num}: {obj.get('type', '?')} missing uuid")
                continue

            entries.add(uid)
            parent = obj.get("parentUuid")
            parent_refs[uid] = parent

            if parent is None:
                roots += 1
            else:
                children.setdefault(parent, []).append(uid)

    broken_parents = []
    for uid, parent in parent_refs.items():
        if parent is not None and parent not in entries:
            broken_parents.append(parent[:12])
    broken = len(broken_parents)

    referenced_as_parent = set(children.keys())
    leaves = [uid for uid in entries if uid not in referenced_as_parent]
    branches = sum(1 for kids in children.values() if len(kids) > 1)

    return {
        "entries": len(entries),
        "nonChainEntries": non_chain,
        "roots": roots,
        "leaves": len(leaves),
        "branches": branches,
        "broken": broken,
        "brokenParents": broken_parents[:5],
        "warnings": warnings,
        "badLines": bad_lines,
    }


